{
  "name": "kufre-server",
  "version": "1.0.0",
  "description": "Kufre Loans — Production-grade Node.js/Express backend for loan management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "schema": "node db/schema.js",
    "seed": "node db/seed.js",
    "setup": "node db/schema.js && node db/seed.js",
    "db:migrate": "node db/schema.js",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/schema.js && node db/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "resend": "^3.2.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
